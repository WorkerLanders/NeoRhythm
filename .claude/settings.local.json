{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); prompt=$(echo \"$input\" | jq -r '.user_prompt // \"\"' 2>/dev/null); if echo \"$prompt\" | grep -iEq '(오디오.*(타이밍|판정|레이턴시|오프셋)|audio.*(timing|judg|latency|offset)|AUDIO_OFFSET|판정.*튜닝|타이밍.*보정|오프셋.*조정|ms.*오프셋)'; then echo '{\"systemMessage\":\"[우선순위 알림] 오디오 타이밍/판정은 개발 최하 우선순위입니다.\",\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"[우선순위 알림] 오디오 타이밍 판정 관련 작업은 사용자가 개발 최하 우선순위로 명시적으로 미뤄둔 항목입니다. 작업을 시작하기 전에 반드시 이 사실을 사용자에게 먼저 알리고, 정말 지금 진행할 것인지 확인을 받으세요.\"}}'; fi; exit 0"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pip list *)",
      "PowerShell(Get-Command python)",
      "PowerShell(node --version)",
      "PowerShell(npm --version)",
      "PowerShell(npm install -g md-to-pdf 2>&1)",
      "PowerShell(Read-Content \"C:\\\\Users\\\\kofpw\\\\AppData\\\\Local\\\\Temp\\\\claude\\\\D--NeoRhythm\\\\1b75a748-cbaa-4582-b28f-ad5e74c7c90f\\\\tasks\\\\b0aop7toz.output\" -ErrorAction SilentlyContinue)",
      "PowerShell(Set-Location \"D:\\\\NeoRhythm\"; $result = & npx md-to-pdf GDD_v0.1.md 2>&1; $result; Write-Host \"Exit: $LASTEXITCODE\")",
      "PowerShell(Get-Process -Name \"chrome\",\"chromium\",\"puppeteer\" -ErrorAction SilentlyContinue)",
