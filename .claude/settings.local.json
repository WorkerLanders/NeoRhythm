      "PowerShell(Get-ChildItem \"$env:USERPROFILE\\\\.cache\\\\puppeteer\\\\chrome\\\\win64-149.0.7827.22\" -Recurse -Filter \"chrome.exe\" | Select-Object FullName)",
      "PowerShell($env:PUPPETEER_EXECUTABLE_PATH = \"C:\\\\Users\\\\kofpw\\\\.cache\\\\puppeteer\\\\chrome\\\\win64-149.0.7827.22\\\\chrome-win64\\\\chrome.exe\"; Set-Location \"D:\\\\NeoRhythm\"; md-to-pdf GDD_v0.1.md; Write-Host \"Done: $LASTEXITCODE\")",
